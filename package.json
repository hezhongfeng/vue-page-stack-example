{
  "name": "vue-page-stack-example",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src vite.config.js",
    "lint-fix": "eslint src vite.config.js --fix",
    "commit:check": "commitlint --from=HEAD~1 --to=HEAD --verbose",
    "prepare": "husky install",
    "format": "prettier --write src/"
  },
  "lint-staged": {
    "*.{vue,js,jsx,tsx}": "eslint src vite.config.js"
  },
  "pnpm": {
    "overrides": {
      "@intlify/shared": "^9.14.2",
      "ajv@^6.0.0": "^6.14.0",
      "ajv@^8.0.0": "^8.18.0",
      "brace-expansion@^1.1.0": "^1.1.13",
      "brace-expansion@^2.0.0": "^2.0.3",
      "cross-spawn": "^7.0.5",
      "diff@^4.0.0": "^4.0.4",
      "esbuild": "^0.25.12",
      "flatted": "^3.4.2",
      "glob@^10.0.0": "^10.5.0",
      "js-yaml": "^4.1.1",
      "lodash": "^4.18.0",
      "micromatch": "^4.0.8",
      "minimatch@^3.0.0": "^3.1.3",
      "minimatch@^9.0.0": "^9.0.7",
      "picomatch": "^2.3.2",
      "rollup": "^4.59.0",
      "tmp": "^0.2.4",
      "yaml": "^2.8.3"
    }
  },
  "dependencies": {
    "@better-scroll/core": "^2.5.1",
    "vant": "^4.9.17",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.6",
    "vue-page-stack": "^3.3.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.35.0",
    "eslint-plugin-vue": "~10.4.0",
    "globals": "^16.4.0",
    "husky": "^8.0.3",
    "jsdom": "^29.0.1",
    "lint-staged": "^13.2.2",
    "sass": "^1.99.0",
    "unplugin-vue-components": "^0.27.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.2"
  }
