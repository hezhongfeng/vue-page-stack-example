{
  "name": "vue-page-stack-example",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src vite.config.js --ext .vue,.js,.jsx,.mjs --ignore-path .gitignore --ignore-pattern \"*.timestamp-*.mjs\"",
    "lint-fix": "eslint src vite.config.js --ext .vue,.js,.jsx,.mjs --fix --ignore-path .gitignore --ignore-pattern \"*.timestamp-*.mjs\"",
    "prepare": "husky install",
    "format": "prettier --write src/"
  },
  "lint-staged": {
    "*.{vue,js,jsx,tsx}": "eslint src vite.config.js --ext .vue,.js,.jsx,.mjs --ignore-path .gitignore --ignore-pattern \"*.timestamp-*.mjs\""
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": "./.cz-config.cjs"
    }
  },
  "dependencies": {
    "@better-scroll/core": "^2.5.1",
    "vant": "^4.9.17",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.5",
    "vue-page-stack": "^3.2.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.6.3",
    "@intlify/unplugin-vue-i18n": "^2.0.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/test-utils": "^2.4.6",
    "commitizen": "^4.3.0",
    "commitlint-config-cz": "^0.13.3",
    "commitlint-config-git-commit-emoji": "^1.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "cz-customizable": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.27.0",
    "husky": "^8.0.3",
    "jsdom": "^29.0.1",
    "lint-staged": "^13.2.2",
    "sass": "^1.77.8",
    "unplugin-vue-components": "^0.27.2",
    "vite": "^6.4.2",
    "vitest": "^1.6.1"
  }
}
